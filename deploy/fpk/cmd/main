#!/bin/bash
ACTION=$1
APP_DIR="$(dirname "$0")/../app"

case "$ACTION" in
  start)
    "$APP_DIR/start.sh"
    exit $?
    ;;
  stop)
    "$APP_DIR/stop.sh"
    exit $?
    ;;
  restart)
    "$APP_DIR/stop.sh"
    sleep 1
    "$APP_DIR/start.sh"
    exit $?
    ;;
  status)
    PID=$(lsof -t -i :8904 2>/dev/null)
    if [ -n "$PID" ]; then
      echo "running"
      exit 0
    else
      echo "stopped"
      exit 3
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac